18),\n    (14, 118..122),\n    (16, 122..125),\n    (16, 125..126),\n    (10, 126..127),\n    (19, 127..129),\n    (19, 129..131),\n    (18, 131..132),\n    (19, 132..134),\n    (18, 134..135),\n    (12, 135..137),\n    (19, 137..139),\n    (19, 139..141),\n    (8, 141..143),\n    (10, 143..145),\n    (17, 145..148),\n    (8, 148..149),\n    (30, 149..152),\n    (19, 152..154),\n    (19, 154..155),\n    (19, 155..157),\n    (19, 157..159),\n    (13, 159..161),\n    (17, 161..162),\n    (12, 162..164),\n    (19, 164..166),\n    (16, 166..168),\n    (22, 168..172),\n    (17, 172..174),\n    (16, 174..176),\n    (17, 176..179),\n    (14, 179..182),\n    (8, 182..183),\n    (14, 183..186),\n    (24, 186..188),\n];\n\npub const SIMPLEX_STROKE_FONT: StrokeFont = StrokeFont {\n    line_height: LINE_HEIGHT,\n    advance: 16,\n    height: SIMPLEX_HEIGHT,\n    cap_height: SIMPLEX_CAP_HEIGHT,\n    positions: &SIMPLEX_POSITIONS,\n    strokes: &SIMPLEX_STROKES,\n    glyphs: &SIMPLEX_GLYPHS,\n};\n"} {:path "src/stroke_text.rs"
